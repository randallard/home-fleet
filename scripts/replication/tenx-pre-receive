#!/usr/bin/env bash
#
# pre-receive — install into each tenx home's hooks/ (via tenx-harden-homes.sh).
#
# Backup integrity (SI): the tenx copy is append-only / fast-forward-only. Reject any
# deletion or non-fast-forward update, so a compromised or buggy controller (acer) cannot
# rewrite or erase backup history. Redundant with receive.denyNonFastForwards/denyDeletes,
# and deliberately so (defense in depth).
#
# Generic — no repo names; safe to publish.
set -euo pipefail

zero="0000000000000000000000000000000000000000"
while read -r old new ref; do
  if [ "$new" = "$zero" ]; then
    echo "reject: deletions are not allowed on the backup ($ref)" >&2; exit 1
  fi
  if [ "$old" != "$zero" ] && ! git merge-base --is-ancestor "$old" "$new"; then
    echo "reject: non-fast-forward update to $ref (backup is ff-only)" >&2; exit 1
  fi
done
exit 0
